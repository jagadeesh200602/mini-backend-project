<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Edit Post</title>
</head>

<body class="bg-zinc-900 flex items-center justify-center min-h-screen">

    <!-- Edit Post Card -->
    <div class="bg-zinc-800 w-full max-w-2xl p-8 rounded-xl shadow-lg">

        <!-- Logout Button -->
        <div class="flex justify-end mb-6">

            <a href="/logout"
               class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg font-semibold">

                Logout

            </a>

        </div>

        <!-- Heading -->

        <h1 class="text-3xl font-bold text-center text-white mb-2">
            Edit Your Post ✏️
        </h1>

        <p class="text-zinc-400 text-center mb-6">
            Update your post and save the changes.
        </p>

        <!-- Form -->

        <form action="/update/<%= post._id %>" method="POST">

            <label class="block mb-2 font-medium">
                Post Content
            </label>

            <textarea
                name="content"
                rows="6"
                placeholder="Write your post..."
                class="w-full p-4 rounded-lg bg-zinc-900 border border-zinc-700 text-white outline-none resize-none focus:border-green-500"><%= post.content %></textarea>

            <button
                type="submit"
                class="w-full mt-5 bg-green-500 hover:bg-green-600 py-3 rounded-lg font-semibold transition">

                Update Post

            </button>

        </form>

    </div>

</body>
</html>