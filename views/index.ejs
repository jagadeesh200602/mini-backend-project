<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Create Account</title>
</head>

<body class="bg-zinc-900 flex items-center justify-center min-h-screen">

    <!-- Register Card -->
    <div class="bg-zinc-800 p-8 rounded-xl shadow-lg w-full max-w-md">

        <!-- Heading -->
        <h1 class="text-3xl font-bold text-white text-center mb-2">
            Create Account 🚀
        </h1>

        <p class="text-zinc-400 text-center mb-6">
            Fill in your details to create an account.
        </p>

        <!-- Form -->
        <form action="/register" method="POST">

            <!-- Name -->
            <div class="mb-4">
                <label class="block mb-2 text-white">Name</label>
                <input
                    type="text"
                    name="name"
                    placeholder="Enter your name"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white outline-none focus:border-blue-500">
            </div>

            <!-- Username -->
            <div class="mb-4">
                <label class="block mb-2 text-white">Username</label>
                <input
                    type="text"
                    name="username"
                    placeholder="Enter your username"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white outline-none focus:border-blue-500">
            </div>

            <!-- Password -->
            <div class="mb-4">
                <label class="block mb-2 text-white">Password</label>

                <div class="relative">

                    <input
                        id="password"
                        type="password"
                        name="password"
                        placeholder="Enter your password"
                        required
                        class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white outline-none focus:border-blue-500">

                    <button
                        type="button"
                        id="eyeBtn"
                        onclick="togglePassword()"
                        class="absolute right-4 top-1/2 -translate-y-1/2">

                        👁️

                    </button>

                </div>
            </div>

            <!-- Email -->
            <div class="mb-4">
                <label class="block mb-2 text-white">Email</label>
                <input
                    type="email"
                    name="email"
                    placeholder="Enter your email"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white outline-none focus:border-blue-500">
            </div>

            <!-- Age -->
            <div class="mb-6">
                <label class="block mb-2 text-white">Age</label>
                <input
                    type="number"
                    name="age"
                    placeholder="Enter your age"
                    required
                    class="w-full px-4 py-3 rounded-lg bg-zinc-900 border border-zinc-700 text-white outline-none focus:border-blue-500">
            </div>

            <!-- Submit Button -->
            <button
                type="submit"
                class="w-full bg-blue-500 hover:bg-blue-600 py-3 rounded-lg font-semibold transition">

                Create Account

            </button>

        </form>

    </div>

    <script>

        function togglePassword() {

            const password = document.getElementById("password");
            const eyeBtn = document.getElementById("eyeBtn");

            if (password.type === "password") {

                password.type = "text";
                eyeBtn.innerHTML = "👁️";

            } else {

                password.type = "password";
                eyeBtn.innerHTML = "👁️";

            }

        }

    </script>

</body>
</html>