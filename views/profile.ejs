<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Profile</title>
</head>

<body class="bg-zinc-900 text-white">

<div class="max-w-4xl mx-auto p-8">

    <!-- Logout Button -->
    <div class="flex justify-end mb-8">
        <a href="/logout"
           class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg font-semibold">
            Logout
        </a>
    </div>

    <!-- Welcome -->
    <div class="mb-10">
        <h1 class="text-4xl font-bold">
            Hello,
            <span class="text-blue-400">
                <%= user.name %>
            </span>
            🫡
        </h1>

        <p class="text-zinc-400 mt-2">
            Create and manage your posts below.
        </p>
    </div>

    <!-- Create Post -->
    <div class="bg-zinc-800 p-6 rounded-xl mb-12">

        <h2 class="text-2xl font-semibold mb-4">
            Create New Post
        </h2>

        <form action="/post" method="POST">

            <textarea
                name="content"
                rows="5"
                placeholder="What's on your mind?"
                class="w-full bg-zinc-900 border border-zinc-700 rounded-lg p-4 outline-none focus:border-blue-500 resize-none"></textarea>

            <button
                class="mt-4 bg-blue-500 hover:bg-blue-600 px-5 py-2 rounded-lg">
                Create Post
            </button>

        </form>

    </div>

    <!-- Posts -->
    <div>

        <h2 class="text-2xl font-semibold mb-6">
            Your Posts
        </h2>

        <% user.post.reverse().forEach(function(post){ %>

            <div class="bg-zinc-800 border border-zinc-700 rounded-xl p-5 mb-5">

                <h3 class="text-blue-400 font-semibold mb-2">
                    @<%= user.username %>
                </h3>

                <p class="text-zinc-200 mb-4">
                    <%= post.content %>
                </p>

                <div class="flex justify-between items-center">

                    <small class="text-zinc-400">
                        ❤️ <%= post.likes.length %> Likes
                    </small>

                    <div class="flex gap-5">

                        <a href="/like/<%= post._id %>"
                           class="text-pink-400 hover:text-pink-300">

                            <%= post.likes.indexOf(user._id) === -1 ? "Like ❤️" : "Unlike 💔" %>

                        </a>

                        <a href="/edit/<%= post._id %>"
                           class="text-blue-400 hover:text-blue-300">

                            Edit ✏️

                        </a>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

</body>
</html>